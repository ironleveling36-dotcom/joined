# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username   # without @

# ── Admin IDs (comma-separated Telegram user IDs) ─────────────────────────────
ADMIN_IDS=123456789,987654321

# ── Bot display settings ──────────────────────────────────────────────────────
BOT_NAME=MyAwesomeBot
WELCOME_TEXT=👋 Welcome to <b>{bot_name}</b>! Please join all channels to continue.

# ── Database (default: SQLite, auto-created as bot.db) ────────────────────────
# For Railway with PostgreSQL, use:
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname
DATABASE_URL=sqlite+aiosqlite:///bot.db

# ── Anti-spam ─────────────────────────────────────────────────────────────────
RATE_LIMIT_SECONDS=3

# ── Broadcast ─────────────────────────────────────────────────────────────────
# Delay in seconds between each message send (0.05 = 20 msg/sec, safe for Telegram)
BROADCAST_DELAY=0.05
